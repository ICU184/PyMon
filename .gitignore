# ═══════════════════════════════════════════════════════════════
#  PyMon .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.egg
*.egg-info/
dist/
build/
*.whl
*.spec

# ── Virtual Environments ──────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ── Testing / Coverage ───────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ── OS ────────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
.DS_Store

# ── Application Data (user-specific, not in repo) ────────────
# SDE database (downloaded at runtime via SDE Updater)
*.db
!tests/*.db

# Token / secrets
*.pem
*.key

# ── PyInstaller ──────────────────────────────────────────────
*.exe
# pymon.spec wird für den CI/CD Build benötigt – NICHT ignorieren
